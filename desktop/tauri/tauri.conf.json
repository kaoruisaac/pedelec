{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pedelec",
  "mainBinaryName": "pedelec-app",
  "version": "0.1.7",
  "identifier": "cc.isaaclin.pedelec",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pedelec",
        "visible": false,
        "width": 1100,
        "height": 760
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": [
      "binaries/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3OEEzNDQ4MTAxQzQ3MQpSV1J4eEFHQlJLTjRDRkkvUlJYQWZDenE0Wk9BUit6cFBNNUwzOWRBV3Q0YkhiRTEwKzVMYmN1RAo=",
      "endpoints": [
        "https://github.com/kaoruisaac/Pedelec/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
